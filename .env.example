# Database — Postgres (e.g. Vercel Postgres / Neon). Used for both local dev
# and production; there is no separate SQLite dev database.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Admin dashboard (protects /admin/*)
ADMIN_PASSWORD="change-me"

# Payments — keep false until you have traffic worth selling to facilities.
# When false: pricing page shows "Coming soon", upgrade buttons are inert,
# and no Stripe API calls are made anywhere in the app.
PAYMENTS_ENABLED=false

# Stripe (test mode keys during development; leave unset while dormant)
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Stripe Price IDs — one per paid upsell (create these as recurring Prices
# in the Stripe dashboard once you're ready to enable payments)
STRIPE_PRICE_FEATURED=""
STRIPE_PRICE_VERIFIED=""
STRIPE_PRICE_PHOTOS=""
STRIPE_PRICE_LEADS=""

# Email (Resend) — used for facility inquiry routing and the contact form.
# Leave unset in development; inquiries are still saved to the database and
# just logged to the console instead of emailed.
RESEND_API_KEY=""
LEAD_FROM_EMAIL="leads@chicagocareforseniors.com"
SITE_CONTACT_EMAIL=""
