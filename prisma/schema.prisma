// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Tier {
  FREE
  FEATURED
}

enum ListingStatus {
  PUBLISHED
  PENDING
}

model Facility {
  id               String        @id @default(cuid())
  name             String
  slug             String        @unique
  address          String?
  city             String
  zip              String?
  county           String
  lat              Float?
  lng              Float?
  phone            String?
  website          String?
  email            String?
  careLevels       Json // string[]
  license          String? // raw license line as sourced; deliberately not over-parsed
  licenseVerified  Boolean       @default(false) // true only when a license # is present and not marked (verify)
  capacity         Int? // best-effort parsed unit/bed count, see capacityNote for full text
  capacityNote     String?
  priceMin         Int?
  priceNote        String?
  priceEstimate    Boolean       @default(true) // false only when price is facility-stated, not an aggregator figure
  medicaidAccepted Boolean       @default(false)
  roomTypes        Json? // string[]
  amenities        Json? // string[]
  awards           Json? // string[]
  yearOpened       Int?
  operator         String?
  summary          String?
  flags            String? // inspection/complaint/financial concerns, verbatim from source
  qualityTier      String? // vetting classification ("Tier 1", "Tier 2", "Affordable/Medicaid") -- NOT the paid tier below
  tier             Tier          @default(FREE) // paid "Featured" placement
  verified         Boolean       @default(false) // paid "Verified" trust badge
  photosUnlocked   Boolean       @default(false) // paid "Photo Gallery" upsell
  leadDeliveryOn   Boolean       @default(false) // paid "Lead Delivery" upsell (routes inquiries by email)
  photos           Json? // string[], gated by photosUnlocked
  status           ListingStatus @default(PUBLISHED)
  reviews          Review[]
  leads            Lead[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([county])
  @@index([tier])
}

// Government-data-driven Listing model (chicago-senior-care-taxonomy.md /
// chicago-senior-care-data-import-plan.md). Distinct from Facility (the
// original 40-facility hand-curated dataset): one Listing per physical
// building, deduped across IDPH/HFS/CMS by addressKey, carrying every care
// type offered there in `categories`.
model Listing {
  id          String        @id @default(cuid())
  name        String
  slug        String        @unique
  address     String
  addressKey  String        @unique // normalized street+zip, the dedup/entity-resolution key (import-plan §3)
  city        String
  county      String
  region      String? // neighborhood, e.g. "Lincoln Park" -- Chicago only
  zip         String?
  lat         Float?
  lng         Float?
  phone       String?
  website     String?
  email       String?
  categories  String[] // every care type at this site, e.g. ["assisted-living","memory-care"]
  status      ListingStatus @default(PENDING)
  enriched    Json // IDPH/HFS/CMS fields + enrichment layer, see import plan §4
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([county])
  @@index([status])
  @@index([categories])
}

model Review {
  id         String   @id @default(cuid())
  facilityId String
  facility   Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  platform   String
  score      Float?
  count      Int?
  note       String?

  @@index([facilityId])
}

model Lead {
  id         String   @id @default(cuid())
  facilityId String
  facility   Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  name       String
  email      String
  phone      String?
  message    String?
  createdAt  DateTime @default(now())

  @@index([facilityId])
}
